{
  "name": "is-valid-tfn",
  "version": "0.1.0",
  "description": "Check if a value is a valid Australian Tax File Number (TFN)",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo --project tsconfig.build.json",
    "clean": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\"",
    "format": "biome format --write .",
    "lint": "biome check .",
    "prepack": "node -e \"fs.rmSync('./dist', { recursive: true, force: true })\" && tsgo --project tsconfig.build.json",
    "typecheck": "tsgo",
    "unit": "vitest run"
  },
  "keywords": [
    "validation",
    "tfn",
    "ato",
    "australia"
  ],
  "author": {
    "name": "Ally Summers",
    "email": "git@ay.ms"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@typescript/native-preview": "latest",
    "vitest": "^4.0.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "!tests/**/*"
  ],
  "packageManager": "pnpm@10.32.1"
}
